<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8">
<title>GiftedHandCo ✨</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>

body{
margin:0;
font-family:'Poppins',sans-serif;
background:linear-gradient(135deg,#f8c8dc,#c8a2c8);
min-height:100vh;
}

header{
text-align:center;
padding:24px;
font-size:28px;
font-weight:600;
color:white;
background:rgba(255,255,255,0.15);
backdrop-filter:blur(10px);
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(170px,1fr));
gap:20px;
padding:25px;
}

.card{
background:white;
border-radius:18px;
padding:15px;
text-align:center;
box-shadow:0 10px 25px rgba(0,0,0,0.1);
transition:all .25s ease;
}

.card:hover{
transform:translateY(-6px);
box-shadow:0 14px 30px rgba(0,0,0,0.18);
}

.card img{
width:100%;
height:160px;
object-fit:cover;
border-radius:12px;
}

button{
background:#c8a2c8;
border:none;
padding:10px 14px;
color:white;
border-radius:8px;
cursor:pointer;
margin-top:8px;
font-size:14px;
transition:0.2s;
}

button:hover{
background:#b88db8;
transform:scale(1.05);
}

button:disabled{
opacity:.6;
cursor:not-allowed;
transform:none;
}

.out{
color:#e53935;
font-weight:600;
}

.cart-btn{
position:fixed;
bottom:25px;
right:25px;
width:65px;
height:65px;
border-radius:50%;
background:#d4af37;
display:flex;
align-items:center;
justify-content:center;
font-size:24px;
color:white;
cursor:pointer;
box-shadow:0 8px 20px rgba(0,0,0,0.25);
}

.cart-count{
position:absolute;
top:-5px;
right:-5px;
background:#ff3b30;
color:white;
font-size:12px;
width:22px;
height:22px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
}

.modal{
position:fixed;
inset:0;
background:rgba(0,0,0,0.5);
display:none;
align-items:center;
justify-content:center;
}

.modal-content{
background:white;
width:90%;
max-width:420px;
padding:22px;
border-radius:16px;
max-height:90vh;
overflow:auto;
animation:pop .25s ease;
}

@keyframes pop{
from{transform:scale(.9);opacity:.6}
to{transform:scale(1);opacity:1}
}

input{
width:100%;
padding:10px;
margin-bottom:10px;
border-radius:8px;
border:1px solid #ddd;
}

.cart-item{
display:flex;
justify-content:space-between;
margin-bottom:8px;
}

.qty-btn{
padding:4px 8px;
font-size:12px;
}

#toast{
position:fixed;
bottom:30px;
left:50%;
transform:translateX(-50%) translateY(100px);
background:#2e7d32;
color:white;
padding:12px 22px;
border-radius:10px;
font-size:14px;
box-shadow:0 6px 18px rgba(0,0,0,0.2);
opacity:0;
transition:all .35s ease;
}

#toast.show{
opacity:1;
transform:translateX(-50%) translateY(0);
}

.loading{
opacity:.6;
pointer-events:none;
}

</style>

</head>

<body>

<header>GiftedHandCo ✨</header>

<div class="grid" id="products"></div>

<div class="cart-btn" onclick="openCart()">
🛒
<div class="cart-count" id="cartCount">0</div>
</div>

<div class="modal" id="cartModal">
<div class="modal-content">

<h3>Your Cart</h3>

<div id="cartItems"></div>

<div id="totals"></div>

<hr>

<input placeholder="Name" id="name">
<input placeholder="Phone" id="phone">
<input type="file" id="screenshot" accept="image/*">

<button id="orderBtn" onclick="placeOrder()">Place Order</button> <button onclick="clearCart()" style="background:#e53935;margin-top:5px">Clear Cart</button> <button onclick="closeCart()" style="background:gray;margin-top:5px">Close</button>

</div>
</div>

<div id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script>

const supabaseClient = supabase.createClient(
"https://mzcfodvfhulmhffhbhpu.supabase.co",
"sb_publishable_6a-rZ0ntq9tBzo4tCESuYw_ZCQwaH_G"
);

let productsData=[];
let cart=JSON.parse(localStorage.getItem("cart"))||[];

function showToast(msg){
const toast=document.getElementById("toast");
toast.textContent=msg;
toast.classList.add("show");
setTimeout(()=>toast.classList.remove("show"),2000);
}

function updateCartCount(){
document.getElementById("cartCount").innerText=cart.reduce((s,i)=>s+i.qty,0);
}

async function loadProducts(){

const {data,error}=await supabaseClient
.from("products")
.select("*")
.eq("active",true);

if(error){
console.error(error);
showToast("Server waking up, refresh in few seconds.");
return;
}

productsData=data;

const container=document.getElementById("products");
container.innerHTML="";

data.forEach(p=>{

container.innerHTML+=`
<div class="card">
<img src="${p.image}">
<h4>${p.name}</h4>
<p>₹${p.price}</p>
<p>Stock: ${p.stock}</p>

${
p.stock>0
? `<button onclick="addToCart('${p.id}')">Add to Cart</button>`
: `<p class="out">Out Of Stock</p>
<button onclick="notify('${p.id}')">Order when in stock</button>`
}

</div>
`;

});

}

function addToCart(id){

let item=cart.find(i=>i.id===id);

if(item){
item.qty+=1;
}else{
const product=productsData.find(p=>p.id===id);
cart.push({...product,qty:1});
}

localStorage.setItem("cart",JSON.stringify(cart));

updateCartCount();

showToast("Added to cart 🛒");

}

function openCart(){
document.getElementById("cartModal").style.display="flex";
renderCart();
}

function closeCart(){
document.getElementById("cartModal").style.display="none";
}

function clearCart(){
cart=[];
localStorage.removeItem("cart");
updateCartCount();
renderCart();
showToast("Cart cleared");
}

function changeQty(id,delta){

let item=cart.find(i=>i.id===id);

if(!item) return;

item.qty+=delta;

if(item.qty<=0){
cart=cart.filter(i=>i.id!==id);
}

localStorage.setItem("cart",JSON.stringify(cart));
updateCartCount();
renderCart();

}

function renderCart(){

let total=0;
const container=document.getElementById("cartItems");
container.innerHTML="";

cart.forEach(item=>{

total+=item.price*item.qty;

container.innerHTML+=`
<div class="cart-item">

<span>${item.name} (x${item.qty})</span>

<div>
<button class="qty-btn" onclick="changeQty('${item.id}',-1)">-</button>
<button class="qty-btn" onclick="changeQty('${item.id}',1)">+</button>
</div>

</div>
`;

});

let discount=total*0.05;
let finalAmount=total-discount;
let advance=Math.ceil(finalAmount*0.2);

document.getElementById("totals").innerHTML=`
<p>Total: ₹${total}</p>
<p>Discount: -₹${discount.toFixed(2)}</p>
<p><b>Final: ₹${finalAmount.toFixed(2)}</b></p>
<p>Advance (20%): ₹${advance.toFixed(2)}</p>
<hr>
<p>UPI: 9390683808@ibl</p>
`;

}

async function placeOrder(){

const btn=document.getElementById("orderBtn");

const name=document.getElementById("name").value.trim();
const phone=document.getElementById("phone").value.trim();
const file=document.getElementById("screenshot").files[0];

if(!name||!phone||!file||cart.length===0){
showToast("Fill all details");
return;
}

if(phone.length<10){
showToast("Enter valid phone number");
return;
}

btn.disabled=true;
btn.innerText="Placing order...";

try{

const cleanName=file.name
.replace(/\s+/g,"_")
.replace(/[^a-zA-Z0-9._-]/g,"");

const fileName=Date.now()+"_"+cleanName;

await supabaseClient.storage
.from("screenshots")
.upload(fileName,file);

const {data:{publicUrl}}=
supabaseClient.storage
.from("screenshots")
.getPublicUrl(fileName);

let total=cart.reduce((s,i)=>s+i.price*i.qty,0);
let discount=total*0.05;
let finalAmount=total-discount;
let advance=finalAmount*0.2;

const {error}=await supabaseClient.rpc("place_order",{
p_order_id:"GH"+Date.now(),
p_name:name,
p_phone:phone,
p_items:cart,
p_total:finalAmount,
p_discount:discount,
p_advance:advance,
p_screenshot_url:publicUrl
});

if(error){
console.error(error);
showToast("Order failed. Try again.");
btn.disabled=false;
btn.innerText="Place Order";
return;
}

showToast("Order placed successfully 🎉");

cart=[];
localStorage.removeItem("cart");
updateCartCount();
closeCart();

}catch(err){

console.error(err);
showToast("Something went wrong");

}

btn.disabled=false;
btn.innerText="Place Order";

}

async function notify(productId){

const name=prompt("Enter your name");
const phone=prompt("Enter phone number");

if(!name||!phone) return;

await supabaseClient
.from("notify_requests")
.insert([{product_id:productId,name,phone}]);

showToast("We'll notify when restocked");

}

updateCartCount();
loadProducts();

</script>

</body>
</html>

